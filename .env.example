# ===============================================
# HALU PLATFORM - Environment Variables Template
# ===============================================
# Copy this file to .env for local development.
# Never commit real secrets to Git.

# --- DJANGO CORE ---
SECRET_KEY="CHANGE_ME_WITH_A_LONG_RANDOM_SECRET"
DEBUG=False
# Comma-separated hostnames/IPs, no spaces
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated full origins with scheme
# Example: https://app.example.com,https://admin.example.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# --- DATABASE (PostgreSQL for production) ---
# Keep settings.py unchanged for now; these are documented for next phase.
DB_ENGINE=django.db.backends.postgresql
DB_NAME=halu_db
DB_USER=halu_user
DB_PASSWORD=CHANGE_ME
DB_HOST=localhost
DB_PORT=5432

# --- CELERY / REDIS ---
CELERY_BROKER_URL=redis://localhost:6379/0
REDIS_URL=redis://127.0.0.1:6379

# --- EXTERNAL APIS ---
GOOGLE_API_KEY=CHANGE_ME

# --- SUPERADMIN ---
SUPERADMIN_MASTER_PASSWORD=CHANGE_ME
