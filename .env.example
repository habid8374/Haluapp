# ===============================================
# HALU PLATFORM - Environment Variables Template
# ===============================================
# Copy this file to .env for local development.
# Never commit real secrets to Git.

# --- DJANGO CORE ---
SECRET_KEY="CHANGE_ME_WITH_A_LONG_RANDOM_SECRET"
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# =============================================================================
# DATABASE (SaaS multi-institucional: una BD compartida; tenant = datos por colegio)
# =============================================================================
#
# Motor predeterminado: PostgreSQL (si USE_SQLITE no está en 1/true/yes/on).
# DB_ENGINE puede omitirse; en ese caso se usa django.db.backends.postgresql.
#
# SQLite solo con USE_SQLITE=1 (recomendado temporalmente si psycopg2 falla en Windows).
#
USE_SQLITE=0
#
# --- PostgreSQL (desarrollo / producción) ---
DB_ENGINE=django.db.backends.postgresql
DB_HOST=localhost
DB_NAME=mi_base_de_datos
DB_USER=mi_usuario
DB_PASSWORD=mi_contraseña
DB_PORT=5432
DB_CONN_MAX_AGE=0
# DB_SSLMODE=require
#
# Checklist manual tras cambiar de motor (mismo código, distinta BD):
# - python manage.py migrate
# - Webhooks Mercado Pago (mp_webhook_secret por InstitucionEducativa)
# - Correos (SMTP por InstitucionEducativa; sin DEFAULT_FROM_EMAIL global)
# - IA Gemini (google_api_key por InstitucionEducativa)

# --- CELERY / REDIS ---
CELERY_BROKER_URL=redis://localhost:6379/0
REDIS_URL=redis://127.0.0.1:6379
# Núcleos del worker (4 por defecto). En SQLite usa 1.
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# --- EMAIL GLOBAL (allauth, password reset, alertas internas) ---
# Si DEBUG=True y EMAIL_BACKEND no se define, los correos van a consola.
# En producción se usa SMTP por defecto. Para forzar, define EMAIL_BACKEND.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=cuenta_interna@ejemplo.com
EMAIL_HOST_PASSWORD=contraseña_de_aplicacion
DEFAULT_FROM_EMAIL="HALU <no-reply@halu.com>"

# --- APIs por institución (Admin > Institución Educativa) ---
# google_api_key, mp_webhook_secret, credenciales SMTP por colegio, etc.

# --- FERNET (cifrado de credenciales en BD) ---
# Genera una clave nueva con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Guarda el resultado aquí y NUNCA lo compartas ni lo commits.
FERNET_KEY=CHANGE_ME_GENERATE_WITH_FERNET

# --- SUPERADMIN (plataforma) ---
SUPERADMIN_MASTER_PASSWORD=CHANGE_ME
