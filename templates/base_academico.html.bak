{% extends "base.html" %}
{% load static %}
{% load notificaciones_tags %}

{% block titulo %}Módulo Académico - {{ branding.NOMBRE }}{% endblock %}

{% block body_class %}layout-academico{% endblock %}

{% block extrastyles %}
    {{ block.super }}
    <style>
        body.layout-academico {
            --brand-primary: #0b5ed7;
            --brand-primary-dark: #0a4db4;
        }
    </style>
{% endblock extrastyles %}


{% block navbar_content %}
    <a class="navbar-brand" href="{% url 'gestion_academica:inicio_academico' %}">
        {% if configuracion_institucion and configuracion_institucion.logo %}
            <img src="{{ configuracion_institucion.logo.url }}" alt="Logo" class="logo-navbar">
        {% else %}
            <i class="bi bi-mortarboard-fill"></i>
        {% endif %}
        {{ configuracion_institucion.nombre_institucion|default:"Módulo Académico" }}
    </a>
    <ul class="navbar-nav ms-auto d-flex flex-row align-items-center">
        {% if user.is_authenticated %}
            {% notificaciones_bell %}
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle ps-2" href="#" id="navbarDropdownUserLink" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-person-circle"></i> {{ user.get_full_name|default:user.username }}
                </a>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdownUserLink">
                    <li><a class="dropdown-item" href="{% url 'gestion_academica:ver_mi_perfil' %}">Mi Perfil</a></li>
                    <li><a class="dropdown-item" href="{% url 'socialaccount_connections' %}">Conexiones de Cuenta</a></li>
                    <li><a class="dropdown-item" href="{% url 'password_change' %}">Cambiar Contraseña</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form id="logout-form-navbar" action="{% url 'logout' %}" method="post" style="display: none;">{% csrf_token %}</form>
                        <a class="dropdown-item" href="#" onclick="document.getElementById('logout-form-navbar').submit(); return false;"><i class="bi bi-box-arrow-right"></i> Cerrar Sesión</a>
                    </li>
                </ul>
            </li>
        {% endif %}
    </ul>
{% endblock navbar_content %}

{% block floating_menu_content %}
     <ul class="nav flex-column">
        <h5 class="menu-section-title">Principal</h5>
        <li class="nav-item item-color-1"><a class="nav-link {% if request.resolver_match.url_name == 'inicio_academico' %}active{% endif %}" href="{% url 'gestion_academica:inicio_academico' %}"><i class="bi bi-house-door-fill"></i> Inicio</a></li>
        

        
        {# ========================================================== #}
        {#      MENÚ PARA ESTUDIANTES                                 #}
        {# ========================================================== #}
        {% if user.rol == 'estudiante' %}
    <hr class="menu-divider">
    <h5 class="menu-section-title">Mi Espacio</h5>
    <li class="nav-item item-color-1">
        <a class="nav-link" href="{% url 'gestion_academica:dashboard_estudiante' %}"><i class="bi bi-grid-1x2-fill"></i> Mi Panel</a>
    </li>
    <li class="nav-item item-color-2">
        <a class="nav-link" href="{% url 'gestion_academica:dashboard_estudiante' %}#seccion-horario"><i class="bi bi-table"></i> Mi Horario</a>
    </li>
    <li class="nav-item item-color-3">
        <a class="nav-link" href="{% url 'gestion_academica:dashboard_estudiante' %}#seccion-calendario"><i class="bi bi-calendar3"></i> Mi Agenda</a>
    </li>
    <li class="nav-item item-color-4">
        <a class="nav-link" href="{% url 'gestion_academica:mi_boletin_periodo_actual' %}"><i class="bi bi-file-earmark-text-fill"></i> Mi Boletín</a>
    </li>
    <li class="nav-item item-color-5">
        <a class="nav-link" href="{% url 'elearning:catalogo' %}"><i class="bi bi-laptop"></i> E-learning</a>
    </li>
{% endif %}
        
        {# ========================================================== #}
        {#      MENÚ PARA ADMINISTRADORES Y PERSONAL (STAFF)          #}
        {# ========================================================== #}
        {% if user.is_staff %}
    
    {# Módulo de Admisiones #}
    {% if perms.admisiones.view_aspirante %}
    <hr class="menu-divider">
    <h5 class="menu-section-title">Procesos</h5>
    <li class="nav-item item-color-3"><a class="nav-link" href="{% url 'admisiones:dashboard_admisiones' %}"><i class="bi bi-bar-chart-line-fill"></i> Módulo de Admisiones</a></li>
    {% endif %}
    {% if user.is_staff %}
    <li class="nav-item item-color-1">
        <a class="nav-link" href="{% url 'gestion_academica:proceso_graduacion' %}">
            <i class="bi bi-patch-check-fill"></i> Proceso de Graduación
        </a>
    </li>
    {% endif %}

    {# --- Módulo de Cursos Virtuales (AÑADIDO) --- #}
    <hr class="menu-divider">
    <h5 class="menu-section-title">E-Learning</h5>
    <li class="nav-item item-color-5">
        <a class="nav-link collapsed" href="#collapseCursos" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="collapseCursos">
            <i class="bi bi-laptop"></i> Cursos Virtuales <i class="bi bi-chevron-down float-end"></i>
        </a>
        <div class="collapse ps-3" id="collapseCursos">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link sub-item" href="{% url 'elearning:catalogo' %}">
                        <i class="bi bi-collection-play"></i> Ir al Aula / Catálogo
                    </a>
                </li>
                {% if perms.elearning.add_curso %}
                <li class="nav-item"><a class="nav-link sub-item" href="{% url 'elearning:gestion_cursos_admin' %}"><i class="bi bi-gear-wide-connected"></i> Gestionar e-learning</a></li>
                <li class="nav-item"><a class="nav-link sub-item" href="{% url 'elearning:matricular_manual' %}"><i class="bi bi-person-check-fill"></i> Matricular en oferta</a></li>
                <li class="nav-item"><a class="nav-link sub-item" href="{% url 'elearning:registrar_estudiante_curso' %}"><i class="bi bi-person-plus-fill"></i> Alta express e-learning</a></li>
                <li class="nav-item"><a class="nav-link sub-item" href="{% url 'elearning:reporte_estadisticas' %}"><i class="bi bi-bar-chart-line"></i> Reporte ventas e-learning</a></li>
                {% endif %}
            </ul>
        </div>
    </li>

    {# Módulo de Gestión Académica #}
    {% if perms.gestion_academica.acceso_modulo_academico %}
