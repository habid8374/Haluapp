        <h5 class="menu-section-title">Gestión General</h5>
        {% if perms.gestion_academica.view_grado %}<li class="nav-item item-color-1"><a class="nav-link" href="{% url 'gestion_academica:lista_grados' %}"><i class="bi bi-diagram-3-fill"></i> Grados</a></li>{% endif %}
        {% if perms.gestion_academica.view_estudiante %}<li class="nav-item item-color-2"><a class="nav-link" href="{% url 'gestion_academica:lista_grados_para_estudiantes' %}"><i class="bi bi-people-fill"></i> Estudiantes</a></li>{% endif %}
        
        <li class="nav-item item-color-6">
    <a class="nav-link" href="{% url 'gestion_academica:admin_asistencia_diaria' %}">
        <i class="bi bi-calendar-check"></i> Control de Asistencia
    </a>
</li>
{% if perms.gestion_academica.view_usuario %}
            <li class="nav-item item-color-blue"> {# Puedes usar un nuevo color #}
                <a class="nav-link" href="{% url 'gestion_academica:lista_usuarios' %}">
                    <i class="bi bi-people-fill"></i> Gestión de Usuarios
                </a>
            </li>
        {% endif %}
        {% if perms.gestion_academica.view_docente %}
<li class="nav-item">
    <a class="nav-link collapsed" href="#submenuDocentes" data-bs-toggle="collapse" role="button" aria-expanded="false" aria-controls="submenuDocentes">
        <i class="bi bi-person-workspace"></i> Docentes <i class="bi bi-chevron-down float-end"></i>
    </a>
    <div class="collapse ps-3" id="submenuDocentes">
