        {% if user.rol == 'egresado' %}
            <hr class="menu-divider">
            <h5 class="menu-section-title">Mi Portal</h5>
            <li class="nav-item item-color-1">
                <a class="nav-link" href="{% url 'gestion_academica:portal_egresado' %}">
                    <i class="bi bi-mortarboard-fill"></i> Portal de Egresado
                </a>
            </li>
        {% endif %}

        <hr class="menu-divider">
        <h5 class="menu-section-title">Cuenta</h5>
        <li class="nav-item item-color-2"><a class="nav-link {% if request.resolver_match.url_name == 'ver_mi_perfil' %}active{% endif %}" href="{% url 'gestion_academica:ver_mi_perfil' %}"><i class="bi bi-person-lines-fill"></i> Mi Perfil</a></li>
        <li class="nav-item item-color-3">
            <form id="logout-form-menu" action="{% url 'logout' %}" method="post" style="display: none;">{% csrf_token %}</form>
            <a class="nav-link" href="#" onclick="event.preventDefault(); document.getElementById('logout-form-menu').submit();"><i class="bi bi-box-arrow-right"></i> Cerrar Sesión</a>
        </li>
    </ul>
{% endblock floating_menu_content %}
{# 👉 ESTE ES EL BLOQUE DE CONTENIDO PRINCIPAL #}
{% block contenido %}
    <div class="container-fluid mt-4">
        <h1 class="h4">Bienvenido/a al Módulo Académico</h1>
        <p class="text-muted">Selecciona una opción del menú para comenzar.</p>
    </div>
{% endblock %}

{% block extra_js %}
     {{ block.super }}

    {% if user.is_authenticated and user.is_staff %}
    <div id="staff-ws-notifications-root" class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1200;" data-institucion-id="{{ user.institucion_asociada_id|default:'' }}">
        <div id="staff-notif-toast" class="toast" role="alert" aria-live="polite" aria-atomic="true" style="cursor: move; min-width: 300px;">
            <div id="staff-notif-header" class="toast-header bg-primary text-white">
                <i id="staff-notif-icon" class="bi bi-bell-fill me-2" aria-hidden="true"></i>
                <strong id="staff-notif-title" class="me-auto">Notificación</strong>
                <button id="staff-notif-close" type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Cerrar"></button>
            </div>
            <div class="toast-body">
                <p id="staff-notif-body" class="small mb-2"></p>
                <a id="staff-notif-link" class="btn btn-sm btn-light mt-2 d-none" href="#">Abrir en admisiones</a>
            </div>
        </div>
    </div>
    <script src="{% static 'js/notifications_staff_ws.js' %}"></script>
    {% endif %}

    {# ── Badge de mensajes no leídos (docente y familiar) ── #}
    {% if user.is_authenticated and user.rol in 'docente,familiar' %}
    <script>
    (function () {
      const badge = document.getElementById('nav-mensajes-badge');
      if (!badge) return;
      function actualizarBadge() {
        fetch("{% url 'mensajeria:api_no_leidos' %}", { credentials: 'same-origin' })
          .then(r => r.ok ? r.json() : null)
          .then(data => {
            if (!data) return;
            if (data.no_leidos > 0) {
              badge.textContent = data.no_leidos > 99 ? '99+' : data.no_leidos;
              badge.style.display = '';
            } else {
              badge.style.display = 'none';
            }
          })
          .catch(() => {});
      }
      actualizarBadge();
      setInterval(actualizarBadge, 30000); // refresca cada 30 s
    })();
    </script>
    {% endif %}
{% endblock extra_js %}
