        <i class="bi bi-clipboard-check-fill"></i> Historial Asistencia Docentes
    </a>
</li>
            {% if perms.gestion_academica.add_docente %}
            <li class="nav-item">
                <a class="nav-link sub-item" href="{% url 'gestion_academica:importar_docentes_excel' %}">
