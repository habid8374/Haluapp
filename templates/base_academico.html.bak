        {% if perms.gestion_academica.view_periodoacademico %}<li class="nav-item item-color-2"><a class="nav-link" href="{% url 'gestion_academica:lista_periodos' %}"><i class="bi bi-calendar-range"></i> Periodos</a></li>{% endif %}
        {% if perms.gestion_academica.view_tipoactividad %}<li class="nav-item item-color-3"><a class="nav-link" href="{% url 'gestion_academica:lista_tipos_actividad' %}"><i class="bi bi-tags-fill"></i> Tipos de Actividad</a></li>{% endif %}
    {% endif %}

            {% if perms.finanzas.acceso_modulo_finanzas %}
