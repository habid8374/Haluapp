        {% if perms.gestion_academica.view_curso %}<li class="nav-item item-color-5"><a class="nav-link" href="{% url 'gestion_academica:lista_cursos' %}"><i class="bi bi-collection-fill"></i> Cursos</a></li>{% endif %}
        {% if perms.gestion_academica.view_aula %}
